# ---------- Build Stage ----------
FROM node:16-alpine AS build

WORKDIR /app
RUN apk add --no-cache git

RUN git clone https://github.com/pelthepu/todo-ui.git .
RUN npm install --legacy-peer-deps

# Inject default env at build time
RUN echo 'window._env_={REACT_APP_API_URL:"/api"};' > public/env-config.js

RUN npm run build

# ---------- Runtime Stage ----------
FROM nginx:alpine

COPY --from=build /app/build /usr/share/nginx/html

# Ensure env config is served
COPY --from=build /app/public/env-config.js /usr/share/nginx/html/env-config.js

# Custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]